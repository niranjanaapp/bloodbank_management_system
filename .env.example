# ─────────────────────────────────────────────────────────
# LifeFlow Blood Bank — Environment Variables
# Copy this file to .env and fill in your actual values.
# .env is listed in .gitignore and will NOT be committed.
# ─────────────────────────────────────────────────────────

# PostgreSQL connection string
# Local example:
DATABASE_URL=postgresql://postgres:yourpassword@localhost:5432/lifeflow

# Cloud examples:
# Supabase:  postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres
# Neon:      postgresql://[USER]:[PASSWORD]@[HOST]/[DBNAME]?sslmode=require

# Server port (optional, defaults to 3000)
PORT=3000
